        local maj = bxor(band(a,b), band(a,c), band(b,c))
        local t2 = add32(s0, maj)
        h,g,f,e,d,c,b,a = g,f,e,add32(d,t1),c,b,a,add32(t1,t2)
    end
    hash[1]=add32(hash[1],a) hash[2]=add32(hash[2],b) hash[3]=add32(hash[3],c) hash[4]=add32(hash[4],d)
    hash[5]=add32(hash[5],e) hash[6]=add32(hash[6],f) hash[7]=add32(hash[7],g) hash[8]=add32(hash[8],h)
