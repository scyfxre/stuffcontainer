local function assertNoHttpSpy()
    if DISABLE_ANTI_HTTP_SPY then return end
    local env = getgenv and getgenv() or _G
    local markers = {"HttpSpy","HTTPSpy","httpspy","__httpspy","__httpSpy","requestSpy","RequestSpy","HTTPRequestLogger","SimpleSpy"}
    for _, name in ipairs(markers) do
        local ok, v = pcall(function() return rawget(env, name) end)
        if ok and v ~= nil then kick("HTTP spy detected") end
    end
end

