local function getHeader(response, name)
    local headers = response.Headers or response.headers or {}
    local target = string.lower(name)
    for k, v in pairs(headers) do
        if string.lower(tostring(k)) == target then return tostring(v) end
    end
    return nil
end

local function assertHex(text)
    if type(text) ~= "string" or (#text % 2) ~= 0 or not text:match("^[0-9a-fA-F]+$") then
        kick("Invalid encrypted payload")
    end
end

local function decryptPayload(encodedHex, hwid, salt)
    assertHex(encodedHex)

    local seed = table.concat({
        tostring(hwid),
        "loader-stream",
        tostring(salt),
    }, "\n")

    local out     = {}
    local block   = ""
    local counter = 0
    local idx     = 1

    for pos = 1, #encodedHex, 2 do
        if ((idx - 1) % 32) == 0 then
            block   = sha256Binary(seed .. "\n" .. tostring(counter))
            counter = counter + 1
        end
        local byte    = tonumber(encodedHex:sub(pos, pos + 1), 16)
        local keyByte = string.byte(block, ((idx - 1) % 32) + 1)
        out[idx] = string.char(bxor(byte, keyByte))
        idx = idx + 1
    end

    return table.concat(out)
end

local function sharedProof(secret, parts)
    local t = { tostring(secret) }
    for i = 1, #parts do t[#t+1] = tostring(parts[i]) end
    return sha256Hex(table.concat(t, "\n"))
end

