    local MOD = 4294967296
    local function normalize(n) return n % MOD end
    local function bxor2(a, b)
        a, b = normalize(a), normalize(b)
        local result, bitValue = 0, 1
        for _ = 0, 31 do
            local aa, bb = a % 2, b % 2
            if aa ~= bb then result = result + bitValue end
            a, b = (a - aa) / 2, (b - bb) / 2
            bitValue = bitValue * 2
        end
        return result
    end
    local function band2(a, b)
        a, b = normalize(a), normalize(b)
        local result, bitValue = 0, 1
        for _ = 0, 31 do
            local aa, bb = a % 2, b % 2
            if aa == 1 and bb == 1 then result = result + bitValue end
            a, b = (a - aa) / 2, (b - bb) / 2
            bitValue = bitValue * 2
        end
        return result
    end
    local function bor2(a, b)
        a, b = normalize(a), normalize(b)
        local result, bitValue = 0, 1
        for _ = 0, 31 do
            local aa, bb = a % 2, b % 2
            if aa == 1 or bb == 1 then result = result + bitValue end
            a, b = (a - aa) / 2, (b - bb) / 2
            bitValue = bitValue * 2
        end
        return result
    end
    function bit.bxor(a, b, ...) local r = bxor2(a, b) for i = 1, select("#", ...) do r = bxor2(r, select(i, ...)) end return r end
    function bit.band(a, b, ...) local r = band2(a, b) for i = 1, select("#", ...) do r = band2(r, select(i, ...)) end return r end
    function bit.bor(a, b, ...) local r = bor2(a, b) for i = 1, select("#", ...) do r = bor2(r, select(i, ...)) end return r end
    function bit.bnot(a) return 4294967295 - normalize(a) end
    function bit.rshift(a, d) if d >= 32 then return 0 end return math.floor(normalize(a) / (2 ^ d)) end
    function bit.lshift(a, d) if d >= 32 then return 0 end return normalize(normalize(a) * (2 ^ d)) end
    function bit.rrotate(a, d) d = d % 32 if d == 0 then return normalize(a) end return bit.bor(bit.rshift(a, d), bit.lshift(a, 32 - d)) end
end

