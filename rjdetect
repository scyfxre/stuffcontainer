local function sha256Binary(msg)
    local hash = {0x6a09e667,0xbb67ae85,0x3c6ef372,0xa54ff53a,0x510e527f,0x9b05688c,0x1f83d9ab,0x5be0cd19}
    msg = preprocess(msg)
    for i = 1, #msg, 64 do digestBlock(msg, i, hash) end
    local o = ""
    for i = 1, 8 do o = o .. numToBytes(hash[i], 4) end
    return o
end

local function toHex(s)
    return (s:gsub(".", function(c) return string.format("%02x", string.byte(c)) end))
end

local function sha256Hex(s) return toHex(sha256Binary(s)) end

