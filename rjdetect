local function numToBytes(v, c)
    local o = ""
    for _ = 1, c do local b = v % 256 o = string.char(b) .. o v = (v - b) / 256 end
    return o
end

local function bytesToNum(s, i)
    local v = 0
    for j = i, i + 3 do v = v * 256 + string.byte(s, j) end
    return v
end

local function preprocess(msg)
    local len = #msg
    local extra = (64 - ((len + 9) % 64)) % 64
    return msg .. string.char(128) .. string.rep(string.char(0), extra) .. numToBytes(8 * len, 8)
end

local function digestBlock(msg, index, hash)
    local w = {}
    for j = 1, 16 do w[j] = bytesToNum(msg, index + (j - 1) * 4) end
    for j = 17, 64 do
        local v1 = w[j-15]
        local s0 = bxor(rrotate(v1,7), rrotate(v1,18), rshift(v1,3))
